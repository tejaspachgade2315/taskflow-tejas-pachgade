POSTGRES_USER=taskflow
POSTGRES_PASSWORD=taskflow
POSTGRES_DB=taskflow
POSTGRES_PORT=5432

API_PORT=8080
FRONTEND_PORT=3000

# Inside Docker network, use service name "postgres" as host
DATABASE_URL=postgres://taskflow:taskflow@postgres:5432/taskflow?sslmode=disable

JWT_SECRET=replace-with-a-long-random-secret
JWT_EXP_HOURS=24
BCRYPT_COST=12

# Browser-facing API URL baked into frontend build
VITE_API_URL=http://localhost:8080

# Allowed frontend origin for CORS at API
ALLOWED_ORIGIN=http://localhost:3000
